<div class="swiper swiper-{{ section.id }}">
  <div class="swiper-wrapper">
    {% for block in section.blocks %}
      {% assign desktop_img = block.settings.image_desktop | image_url: width: 1600 %}
      {% assign mobile_img = block.settings.image_mobile | image_url: width: 800 %}
      <div class="swiper-slide">
        <a href="{{ block.settings.link | default: '#' }}">
          <picture>
            <source media="(max-width: 749px)" srcset="{{ mobile_img |  image_url: width: 2048  }}">
            <img
              src="{{ desktop_img |  image_url: width: 2048  }}"
              alt="Slide"
              loading="lazy">
          </picture>
        </a>
      </div>
    {% endfor %}
  </div>

  <!-- Custom Arrows -->
  <div class="custom-swiper-button-prev-{{ section.id }}">
    <svg
      width="32"
      height="32"
      viewBox="0 0 24 24">
      <path fill="#000" d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z" />
    </svg>
  </div>
  <div class="custom-swiper-button-next-{{ section.id }}">
    <svg
      width="32"
      height="32"
      viewBox="0 0 24 24">
      <path fill="#000" d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6z" />
    </svg>
  </div>

  <!-- Pagination -->
  <div class="swiper-pagination swiper-pagination-{{ section.id }}"></div>
</div>

<style>
  .swiper-{{ section.id }} {
    width: 100%;
    position: relative;
  }

  .swiper-{{ section.id }}
  .swiper-slide img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Pagination Dots */
  .swiper-pagination-{{ section.id }} .swiper-pagination-bullet {
    background: #ffffff;
    opacity: 1;
    transition: transform 0.3s ease
    , background-color 0.3s ease;
  }

  .swiper-pagination-{{ section.id }}
  .swiper-pagination-bullet-active {
    background: rgba(255, 255, 255, 0.425);
    transform: scale(1.3);
  }

  /* Custom Arrows */
  .custom-swiper-button-prev-{{ section.id }}
  , .custom-swiper-button-next-{{ section.id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 32px;
    height: 32px;
    background: #fff;
    border-radius: 100%;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
    cursor: pointer;
    transition: opacity 0.3s ease
    , transform 0.3s ease;
  }

  .custom-swiper-button-prev-{{ section.id }}:hover,
  .custom-swiper-button-next-{{ section.id }}:hover {
    opacity: 1;
    transform: translateY(-50%) scale(1.05);
  }

  .custom-swiper-button-prev-{{ section.id }} {
    left: 10px;
  }

  .custom-swiper-button-next-{{ section.id }} {
    right: 10px;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var swiperEl = document.querySelector('.swiper-{{ section.id }}');
    var slidesCount = swiperEl.querySelectorAll('.swiper-slide').length;
  
    var swiperInstance = new Swiper('.swiper-{{ section.id }}', {
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false
      },
      navigation: {
        nextEl: '.custom-swiper-button-next-{{ section.id }}',
        prevEl: '.custom-swiper-button-prev-{{ section.id }}'
      },
      pagination: {
        el: '.swiper-pagination-{{ section.id }}',
        clickable: true
      }
    });
  
    if (slidesCount < 2) {
      document.querySelector('.custom-swiper-button-next-{{ section.id }}').style.display = 'none';
      document.querySelector('.custom-swiper-button-prev-{{ section.id }}').style.display = 'none';
    }
  });
</script>

{% schema %}
  {
    "name": "Slideshow con Swiper",
    "settings": [],
    "blocks": [
      {
        "type": "slide",
        "name": "Slide",
        "settings": [
          {
            "type": "image_picker",
            "id": "image_desktop",
            "label": "Imagen de escritorio"
          }, {
            "type": "image_picker",
            "id": "image_mobile",
            "label": "Imagen móvil"
          }, {
            "type": "url",
            "id": "link",
            "label": "Enlace del slide"
          }
        ]
      }
    ],
    "max_blocks": 10,
    "presets": [
      {
        "name": "Slideshow con Swiper",
        "category": "Media"
      }
    ]
  }
{% endschema %} 