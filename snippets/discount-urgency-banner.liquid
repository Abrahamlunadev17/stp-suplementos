{% comment %}
  Snippet: discount-reminder-bar
  Uso: {% render 'discount-urgency-banner' %}
{% endcomment %}

<div class="drb-bar">
  <p class="drb-text">
    🎁 Obtén un <strong>10% de descuento</strong> en tu compra &mdash; usa el código:
  </p>
  <div class="drb-code-wrap">
    <span class="drb-code">FNT10</span>
    <button class="drb-copy" id="drb-copy">Copiar</button>
  </div>
</div>

<style>
  .drb-bar {
    background: #111;
    border-bottom: 2px solid #e00;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .drb-text {
    margin: 0;
    font-size: 13px;
    color: #ccc;
    font-family: sans-serif;
    white-space: nowrap;
  }

  .drb-text strong {
    color: #e00;
  }

  .drb-code-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .drb-code {
    font-family: monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #fff;
    background: #222;
    border: 1px dashed #e00;
    padding: 4px 12px;
    border-radius: 2px;
  }

  .drb-copy {
    background: #e00;
    color: #fff;
    border: none;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 700;
    font-family: sans-serif;
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s;
    letter-spacing: 0.5px;
  }

  .drb-copy:hover { background: #c00; }
  .drb-copy.copied { background:rgb(43, 43, 43); }
</style>

<script>
  document.getElementById('drb-copy').addEventListener('click', function () {
    const btn = this;
    const code = 'FNT10';

    // Método moderno (Chrome, Firefox, Android)
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(code).then(() => {
        showCopied(btn);
      }).catch(() => {
        fallbackCopy(code, btn);
      });
    } else {
      // Fallback para Safari/iPhone
      fallbackCopy(code, btn);
    }
  });

  function fallbackCopy(text, btn) {
    // Crea un input temporal, lo selecciona y ejecuta copy
    const input = document.createElement('input');
    input.setAttribute('value', text);
    input.setAttribute('readonly', '');
    input.style.cssText = 'position:fixed;top:0;left:0;opacity:0;';
    document.body.appendChild(input);

    // En iOS hay que usar setSelectionRange
    input.focus();
    input.setSelectionRange(0, 999);
    
    try {
      document.execCommand('copy');
      showCopied(btn);
    } catch (e) {
      // Si todo falla, al menos muestra el código para copiar manualmente
      btn.textContent = 'FNT10';
    }

    document.body.removeChild(input);
  }

  function showCopied(btn) {
    btn.textContent = '¡Copiado!';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.textContent = 'Copiar';
      btn.classList.remove('copied');
    }, 2000);
  }
</script>