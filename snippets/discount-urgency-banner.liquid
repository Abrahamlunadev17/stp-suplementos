{% comment %}
  Snippet: discount-reminder-bar
  Uso: {% render 'discount-urgency-banner' %}
{% endcomment %}

<div class="drb-bar">
  <p class="drb-text">
    🎁 Obtén un <strong>10% de descuento</strong> en tu compra &mdash; usa el código:
  </p>
  <div class="drb-code-wrap">
    <span class="drb-code">FNT10</span>
    <button class="drb-copy" id="drb-copy">Copiar</button>
  </div>
</div>

<style>
  .drb-bar {
    background: #111;
    border-bottom: 2px solid #e00;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .drb-text {
    margin: 0;
    font-size: 13px;
    color: #ccc;
    font-family: sans-serif;
    white-space: nowrap;
  }

  .drb-text strong {
    color: #e00;
  }

  .drb-code-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .drb-code {
    font-family: monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #fff;
    background: #222;
    border: 1px dashed #e00;
    padding: 4px 12px;
    border-radius: 2px;
  }

  .drb-copy {
    background: #e00;
    color: #fff;
    border: none;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 700;
    font-family: sans-serif;
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s;
    letter-spacing: 0.5px;
  }

  .drb-copy:hover { background: #c00; }
  .drb-copy.copied { background:rgb(43, 43, 43); }
</style>

<script>
  document.getElementById('drb-copy').addEventListener('click', function () {
    navigator.clipboard.writeText('FNT10').then(() => {
      this.textContent = '¡Copiado!';
      this.classList.add('copied');
      setTimeout(() => {
        this.textContent = 'Copiar';
        this.classList.remove('copied');
      }, 2000);
    });
  });
</script>